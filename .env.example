# Database — local SQLite (path is relative to prisma/schema.prisma → prisma/dev.db)
# Production (Neon): postgresql://... pooled URL + set provider to postgresql in schema.prisma
DATABASE_URL="file:./dev.db"

# Auth — Admin
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AUTH_SECRET=
ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=

# Auth — Client Portal
CLIENT_PORTAL_SECRET=

# Google OAuth (Admin login + GA/GSC integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Gmail — free)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=Your Web Agency

# Encryption for OAuth tokens (generate: openssl rand -base64 32)
ENCRYPTION_KEY=
ENCRYPTION_KEY_VERSION=1

# Payments (defer until needed)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# File Storage (defer — use logo URLs in AgencyProfile for now)
BLOB_READ_WRITE_TOKEN=

# APIs
PAGESPEED_API_KEY=
CRON_SECRET=

# Google Search Console Indexing API [v2]
GOOGLE_INDEXING_CLIENT_EMAIL=
GOOGLE_INDEXING_PRIVATE_KEY=
